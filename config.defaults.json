  "browser_detection": {
    "windows": {
      "registry_hive": "HKEY_CURRENT_USER",
      "subkey": "Software\\Microsoft\\Windows\\Shell\\Associations\\UrlAssociations\\http\\UserChoice",
      "value_name": "ProgId",
      "fallback": "edge",
      "rules": [
        {"browser": "firefox", "haystack_contains": ["firefox"]},
        {"browser": "edge", "haystack_contains": ["edge", "msedge"]},
        {"browser": "chrome", "haystack_contains": ["chrome"]},
        {"browser": "brave", "haystack_contains": ["brave"]}
      ]
    },
    "linux": {
      "command": ["xdg-mime", "query", "default", "x-scheme-handler/http"],
      "fallback": "firefox",
      "rules": [
        {"browser": "firefox", "haystack_contains": ["firefox"]},
        {"browser": "chromium", "haystack_contains": ["chromium"]},
        {"browser": "chrome", "haystack_contains": ["google-chrome", "chrome"]},
        {"browser": "brave", "haystack_contains": ["brave"]},
        {"browser": "edge", "haystack_contains": ["microsoft-edge", "edge"]}
      ]
    },
    "darwin": {
      "command": [
        "defaults",
        "read",
        "com.apple.LaunchServices/com.apple.launchservices.secure",
        "LSHandlers"
      ],
      "fallback": "safari",
      "rules": [
        {"browser": "firefox", "haystack_contains": ["firefox"]},
        {"browser": "chrome", "haystack_contains": ["chrome"]},
        {"browser": "edge", "haystack_contains": ["edge"]}
      ]
    },
    "fallback_other": "chrome"
  },
