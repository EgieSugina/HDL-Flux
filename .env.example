# Copy to .env and adjust. Loaded before config.json; does not override existing OS env vars.
#
# --- Windows (samples; use your username and drive letters) ---
# Paths may use forward slashes (recommended in .env) or escaped backslashes.
# HDL_CONFIG=C:/Users/YourName/LABs/hls-downloader/config.json
# HDL_PATHS_BASE_DIR=C:/Users/YourName/Videos/hls-downloader
# HDL_PATHS_LIST_FILE=C:/Users/YourName/LABs/hls-downloader/list.txt
# HDL_PATHS_SKIP_IF_EXISTS_DIRS=D:/Anime,C:/Users/YourName/Videos
#
# --- Linux / macOS ---
# HDL_CONFIG=/absolute/path/to/alternate.json
# YouTube-only profile (see config.youtube.json):
# HDL_CONFIG=config.youtube.json
# HDL_PROXY_DEFAULT_URL=socks5://127.0.0.1:1080
# HDL_PATHS_LIST_FILE=list.txt
# HDL_PATHS_BASE_DIR=__script__
# Optional: comma-separated extra directories checked before hstream download.
# If a file with same slug name already exists there, download is skipped.
# Example:
# HDL_PATHS_SKIP_IF_EXISTS_DIRS=/home/user/Videos
# HDL_HSTREAM_BASE_URL=https://hstream.moe
# HDL_HSTREAM_REFERER=https://hstream.moe/
# HDL_HSTREAM_ORIGIN=https://hstream.moe
# HDL_GENERIC_OUTPUT_DIR_DEFAULT=downloads
# HDL_UI_WORKERS_DEFAULT=4
# HDL_HSTREAM_MAX_RETRIES=4
# HDL_GENERIC_MAX_RETRIES=4
# HDL_GENERIC_RETRY_DELAY_SEC=15
